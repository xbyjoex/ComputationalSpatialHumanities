# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=leipzig_data
POSTGRES_USER=leipzig
POSTGRES_PASSWORD=

# ── Backend API ───────────────────────────────────────────────────────────────
SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://auerbachs-auge.tech

# ── Leipzig Open Data ─────────────────────────────────────────────────────────
LEIPZIG_API_BASE=https://opendata.leipzig.de/api/3
LEIPZIG_STAT_API_BASE=https://statistik.leipzig.de/opendata/api

# ── ETL ───────────────────────────────────────────────────────────────────────
ETL_NIGHTLY_CRON=0 2 * * *
ETL_LIVE_INTERVAL_SECONDS=300
ETL_REQUEST_TIMEOUT_SECONDS=60
ETL_MAX_RETRIES=3
ETL_BACKOFF_FACTOR=2.0

# ── Redis (optional cache) ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Domain (used by nginx TLS config) ────────────────────────────────────────
DOMAIN=auerbachs-auge.tech

# ── Telegram Notifications & Registrierungs-Freigabe ─────────────────────────
# Bot erstellen: @BotFather → /newbot
# Chat-ID: Bot anschreiben → https://api.telegram.org/bot<TOKEN>/getUpdates
# Genutzt vom ETL (Notifications, Befehle, Freigabe-Buttons) UND vom Backend
# (POST /auth/register schickt die Freigabe-Anfrage in denselben Chat).
# Ohne diese Variablen antwortet /auth/register mit 503.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Monitoring ────────────────────────────────────────────────────────────────
UPTIME_KUMA_PUSH_URL=

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=leipzig-data-backups
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
